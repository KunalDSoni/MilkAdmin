// Moderns Milk — Prisma schema (Slice 1: Foundation + Ordering Core)
//
// Correctness rules baked in:
//   * All money = Decimal(12,2); all quantities = Decimal(12,3). No floats.
//   * LedgerEntry is append-only (no updates in app code).
//   * AuditLog records every financial / approval / state transition.
//   * Order / OrderItem indexed on deliveryDate for future range partitioning.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum OutletType {
  NEW
  EXISTING
}

enum Role {
  ADMIN
  SALES_HEAD
  SALES_OFFICER
  DISTRIBUTOR
  RETAILER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

// Onboarding lifecycle for distributors / retailers (spec §2.8).
// PENDING: details captured, not yet onboarded.
// PROSPECTIVE: samples taken, under evaluation.
// ONBOARDED: active on the platform.
// REJECTED: declined — rejection note is mandatory.
enum OnboardingStatus {
  PENDING
  PROSPECTIVE
  ONBOARDED
  REJECTED
}

enum ProductCategory {
  MILK
  DAIRY
}

enum Uom {
  LITRE
  ML
  KG
  GRAM
  PIECE
  POUCH
}

// Ordering quantity type (spec §3.2.3) — a product is ordered by the crate or
// by the individual unit, which sets the min/max the buyer may order.
enum OrderUnit {
  CRATE
  UNIT
}

enum OrderWindowStatus {
  OPEN // accepting / editing orders
  LOCKED // cutoff passed, frozen for production
  DISPATCHED
  CLOSED
}

enum OrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  IN_PRODUCTION
  DISPATCHED
  DELIVERED
  SETTLED
  CANCELLED
}

enum OrderSource {
  STANDING
  MANUAL
}

// Retailer order vs a distributor self-order for hawkers / individual
// deliveries (spec §2.5-2.7). Both follow the same approval flow.
enum OrderType {
  RETAILER
  SELF
}

enum ApprovalType {
  AUTO
  MANUAL
}

enum LedgerEntryType {
  DEBIT // increases what the retailer owes
  CREDIT // payment / adjustment reducing what they owe
}

enum ReturnReason {
  SHORT_SUPPLY
  DAMAGE
  EXPIRY
  REJECTED
}

// ---------------------------------------------------------------------------
// Identity & org
// ---------------------------------------------------------------------------

model User {
  id           String     @id @default(cuid())
  phone        String     @unique
  name         String
  email        String?    @unique
  role         Role
  status       UserStatus @default(ACTIVE)
  passwordHash String? // bcrypt hash for password auth (Epic 1)

  // Staff (SALES_OFFICER / DISTRIBUTOR) may be scoped to a distributor.
  // Used by the tenant-scope guard so a user can never read another org's data.
  distributorId String?
  distributor   Distributor? @relation("DistributorStaff", fields: [distributorId], references: [id])

  // Onboarding attributes captured for staff (SALES_HEAD / SALES_OFFICER).
  area    String?
  subArea String?

  // A SALES_OFFICER reports to a SALES_HEAD. Self-relation kept nullable so
  // heads and admins have no manager.
  reportsToId String?
  reportsTo   User?   @relation("StaffReporting", fields: [reportsToId], references: [id])
  reports     User[]  @relation("StaffReporting")

  retailer             Retailer?
  registeredRetailers  Retailer[]    @relation("RetailerSalesOfficer")
  assignedDistributors Distributor[] @relation("DistributorSalesOfficer")
  salesVisits          SalesVisit[]  @relation("VisitSalesOfficer")
  sampleOrders         SampleOrder[] @relation("SampleOrderPlacedBy")
  recordedPayments     PaymentLog[]  @relation("PaymentRecordedBy")
  approvedOrders       Order[]       @relation("OrderApprovedBy")
  rejectedOrders       Order[]       @relation("OrderRejectedBy")
  auditLogs            AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([distributorId])
  @@index([reportsToId])
}

model Distributor {
  id      String     @id @default(cuid())
  code    String     @unique
  name    String
  region  String?
  subArea String?
  address String?
  status  UserStatus @default(ACTIVE)

  // Onboarding details (spec §2.8.1). No verification in this phase.
  pan             String?
  bankDetails     String?
  securityDeposit Decimal? @db.Decimal(12, 2)

  onboardingStatus OnboardingStatus @default(PENDING)
  onboardingNote   String? // mandatory when REJECTED (enforced in service)

  // Sales officer who manages this distributor. Drives role-scoped visibility
  // (a SO sees their distributors; a SH sees their officers' distributors).
  assignedSalesOfficerId String?
  assignedSalesOfficer   User?   @relation("DistributorSalesOfficer", fields: [assignedSalesOfficerId], references: [id])

  staff        User[]        @relation("DistributorStaff")
  retailers    Retailer[]
  routes       Route[]
  orders       Order[]
  windows      OrderWindow[]
  salesVisits  SalesVisit[]
  sampleOrders SampleOrder[]
  payments     PaymentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Route {
  id            String      @id @default(cuid())
  distributorId String
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  name          String
  sequence      Int         @default(0)

  retailers Retailer[]
  windows   OrderWindow[]

  createdAt DateTime @default(now())

  @@unique([distributorId, name])
  @@index([distributorId])
}

model Retailer {
  id            String      @id @default(cuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id])
  distributorId String
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  routeId       String?
  route         Route?      @relation(fields: [routeId], references: [id])

  shopName     String
  gstin        String?
  addressLine  String?
  whatsapp     String?
  paymentTerms String?
  outletType   OutletType @default(EXISTING)
  lat          Float?
  lng          Float?
  status       UserStatus @default(ACTIVE)

  // Onboarding details collected from the retailer (spec §2.8.2).
  subArea           String?
  pan               String?
  shopLicenseNo     String?
  licenseImageKey   String? // object-store key for the uploaded license image
  securityDeposit   Decimal?  @db.Decimal(12, 2)
  monthlyTurnover   Decimal?  @db.Decimal(14, 2)
  shopEstablishedOn String? // "YYYY-MM" month & year of establishment
  brandsDealing     String[] // brands the outlet currently deals in
  productsSold      String[] // products currently sold
  instrumentNo      String? // security-deposit instrument / cheque no.
  instrumentDate    DateTime?

  onboardingStatus OnboardingStatus @default(PENDING)
  onboardingNote   String? // mandatory when REJECTED (enforced in service)

  // Sales person who brought this outlet in — kept centrally so HQ retains
  // the relationship even if the distributor changes.
  salesOfficerId String?
  salesOfficer   User?   @relation("RetailerSalesOfficer", fields: [salesOfficerId], references: [id])

  account        RetailerAccount?
  standingOrders StandingOrder[]
  orders         Order[]
  ledgerEntries  LedgerEntry[]
  salesVisits    SalesVisit[]
  sampleOrders   SampleOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([distributorId, routeId])
}

// Append-derived balance lives here; truth is the LedgerEntry stream.
model RetailerAccount {
  id          String   @id @default(cuid())
  retailerId  String   @unique
  retailer    Retailer @relation(fields: [retailerId], references: [id])
  balance     Decimal  @default(0) @db.Decimal(12, 2)
  creditLimit Decimal  @default(0) @db.Decimal(12, 2)

  updatedAt DateTime @updatedAt
}

// Generic key/value for admin-managed global settings (spec §8) — e.g. the
// order placement deadline. Kept simple so new toggles slot in without a migration.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Catalog & pricing
// ---------------------------------------------------------------------------

model Product {
  id               String          @id @default(cuid())
  sku              String          @unique
  name             String
  category         ProductCategory
  uom              Uom
  packSize         Decimal         @db.Decimal(12, 3) // e.g. 0.500 L, 1.000 L
  hsnCode          String?
  taxRate          Decimal         @default(0) @db.Decimal(5, 2) // GST %
  isReturnablePack Boolean         @default(false)
  shelfLifeDays    Int?
  active           Boolean         @default(true)

  // Ordering rules (spec §3.5.3). orderUnit sets whether min/max is counted in
  // crates or units; unitPrice is the price per that unit.
  orderUnit   OrderUnit @default(UNIT)
  minOrderQty Decimal?  @db.Decimal(12, 3)
  maxOrderQty Decimal?  @db.Decimal(12, 3)
  unitPrice   Decimal?  @db.Decimal(12, 2)

  priceItems         PriceListItem[]
  standingOrderItems StandingOrderItem[]
  salesVisitItems    SalesVisitItem[]
  orderItems         OrderItem[]
  sampleOrderItems   SampleOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, active])
}

model PriceList {
  id           String    @id @default(cuid())
  name         String
  customerTier String    @default("RETAILER") // RETAILER | DISTRIBUTOR
  region       String?
  validFrom    DateTime
  validTo      DateTime?

  items PriceListItem[]

  createdAt DateTime @default(now())

  @@index([customerTier, validFrom])
}

model PriceListItem {
  id          String    @id @default(cuid())
  priceListId String
  priceList   PriceList @relation(fields: [priceListId], references: [id])
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  price       Decimal   @db.Decimal(12, 2)

  @@unique([priceListId, productId])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// Ordering
// ---------------------------------------------------------------------------

// One window per distributor (optionally per route) per delivery date.
// Orders auto-lock at cutoffAt so production gets a stable demand signal.
model OrderWindow {
  id            String            @id @default(cuid())
  distributorId String
  distributor   Distributor       @relation(fields: [distributorId], references: [id])
  routeId       String?
  route         Route?            @relation(fields: [routeId], references: [id])
  deliveryDate  DateTime          @db.Date
  cutoffAt      DateTime
  status        OrderWindowStatus @default(OPEN)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([distributorId, routeId, deliveryDate])
  @@index([status, cutoffAt])
}

model StandingOrder {
  id          String   @id @default(cuid())
  name        String?
  retailerId  String
  retailer    Retailer @relation(fields: [retailerId], references: [id])
  // 7-bit weekday mask, Monday = bit 0. 127 = every day.
  weekdayMask Int      @default(127)
  active      Boolean  @default(true)

  items StandingOrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([retailerId, active])
}

model StandingOrderItem {
  id              String        @id @default(cuid())
  standingOrderId String
  standingOrder   StandingOrder @relation(fields: [standingOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id])
  qty             Decimal       @db.Decimal(12, 3)

  @@unique([standingOrderId, productId])
}

model Order {
  id            String      @id @default(cuid())
  retailerId    String
  retailer      Retailer    @relation(fields: [retailerId], references: [id])
  distributorId String
  distributor   Distributor @relation(fields: [distributorId], references: [id])
  orderWindowId String
  orderWindow   OrderWindow @relation(fields: [orderWindowId], references: [id])
  deliveryDate  DateTime    @db.Date

  status       OrderStatus   @default(DRAFT)
  source       OrderSource   @default(MANUAL)
  orderType    OrderType     @default(RETAILER)
  approvalType ApprovalType?

  // Review metadata (spec §4.1.5) — who approved/rejected, why, and when.
  approvedById String?
  approvedBy   User?     @relation("OrderApprovedBy", fields: [approvedById], references: [id])
  rejectedById String?
  rejectedBy   User?     @relation("OrderRejectedBy", fields: [rejectedById], references: [id])
  rejectReason String?
  reviewedAt   DateTime?

  subtotal Decimal @default(0) @db.Decimal(12, 2)
  taxTotal Decimal @default(0) @db.Decimal(12, 2)
  total    Decimal @default(0) @db.Decimal(12, 2)

  items      OrderItem[]
  salesVisit SalesVisit?
  payments   PaymentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([retailerId, deliveryDate])
  @@index([distributorId, deliveryDate])
  @@index([orderWindowId, status])
  @@index([deliveryDate]) // partition key candidate
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])

  unitPrice Decimal @db.Decimal(12, 2)

  // Multi-stage quantities — ordered != dispatched != delivered != accepted.
  qtyOrdered    Decimal       @db.Decimal(12, 3)
  qtyApproved   Decimal?      @db.Decimal(12, 3)
  qtyDispatched Decimal?      @db.Decimal(12, 3)
  qtyDelivered  Decimal?      @db.Decimal(12, 3)
  qtyReturned   Decimal       @default(0) @db.Decimal(12, 3)
  returnReason  ReturnReason?

  @@unique([orderId, productId])
  @@index([orderId])
}

// ---------------------------------------------------------------------------
// Sample orders (spec §4/§5) — free product allotted to prospects by sales
// staff to win them over. Distinct from real Orders: no pricing, no ledger,
// no approval workflow — just who got what, and when.
// ---------------------------------------------------------------------------

enum SampleTargetType {
  DISTRIBUTOR
  RETAILER
}

model SampleOrder {
  id String @id @default(cuid())

  // Sales officer / head who placed it.
  placedById String
  placedBy   User   @relation("SampleOrderPlacedBy", fields: [placedById], references: [id])

  targetType    SampleTargetType
  distributorId String?
  distributor   Distributor?     @relation(fields: [distributorId], references: [id])
  retailerId    String?
  retailer      Retailer?        @relation(fields: [retailerId], references: [id])

  deliveryDate DateTime
  note         String?

  items SampleOrderItem[]

  createdAt DateTime @default(now())

  @@index([placedById, createdAt])
  @@index([targetType, createdAt])
}

model SampleOrderItem {
  id            String      @id @default(cuid())
  sampleOrderId String
  sampleOrder   SampleOrder @relation(fields: [sampleOrderId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  qty           Decimal     @db.Decimal(12, 3)

  @@unique([sampleOrderId, productId])
  @@index([sampleOrderId])
}

// ---------------------------------------------------------------------------
// Payment logs (spec §6) — money a distributor pays their sales officer.
// Distributors record the payment (with a proof image); only an ADMIN may flip
// the status PENDING -> PAID. Kept separate from the retailer LedgerEntry stream.
// ---------------------------------------------------------------------------

enum PaymentMode {
  CASH
  UPI
  CHEQUE
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
}

model PaymentLog {
  id String @id @default(cuid())

  distributorId String
  distributor   Distributor @relation(fields: [distributorId], references: [id])

  // Optional link to the order this payment settles.
  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  // Who logged it (typically the distributor's own user).
  recordedById String
  recordedBy   User   @relation("PaymentRecordedBy", fields: [recordedById], references: [id])

  amount        Decimal       @db.Decimal(12, 2)
  paymentDate   DateTime
  mode          PaymentMode
  status        PaymentStatus @default(PENDING)
  proofImageKey String? // object-store key for the uploaded transaction proof
  note          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([distributorId, createdAt])
  @@index([status])
}

// Field-sales "beat" record — a rep's visit to an outlet. Captures the visit
// metadata centrally (HQ-owned) and optionally links the fulfillment order it
// generated. Route is a free-text snapshot; the rest are real references.
model SalesVisit {
  id   String   @id @default(cuid())
  date DateTime @db.Date

  dayStartAt DateTime?

  salesOfficerId String
  salesOfficer   User   @relation("VisitSalesOfficer", fields: [salesOfficerId], references: [id])

  distributorId String
  distributor   Distributor @relation(fields: [distributorId], references: [id])

  retailerId String
  retailer   Retailer @relation(fields: [retailerId], references: [id])

  routeName   String?
  outletType  OutletType @default(EXISTING)
  inTime      DateTime?
  bookingTime DateTime?
  competition String?
  remarks     String?

  // The fulfillment order this booking generated, if any.
  orderId String? @unique
  order   Order?  @relation(fields: [orderId], references: [id])

  items SalesVisitItem[]

  createdAt DateTime @default(now())

  @@index([distributorId, date])
  @@index([salesOfficerId, date])
}

model SalesVisitItem {
  id        String     @id @default(cuid())
  visitId   String
  visit     SalesVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  productId String
  product   Product    @relation(fields: [productId], references: [id])
  qty       Decimal    @db.Decimal(12, 3)

  @@unique([visitId, productId])
}

// ---------------------------------------------------------------------------
// Ledger (append-only) & audit (schema only this slice; behavior in slice 2)
// ---------------------------------------------------------------------------

model LedgerEntry {
  id           String          @id @default(cuid())
  retailerId   String
  retailer     Retailer        @relation(fields: [retailerId], references: [id])
  type         LedgerEntryType
  amount       Decimal         @db.Decimal(12, 2)
  refType      String // ORDER | PAYMENT | ADJUSTMENT | DEPOSIT
  refId        String?
  balanceAfter Decimal         @db.Decimal(12, 2)
  note         String?

  createdAt DateTime @default(now())

  @@index([retailerId, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id])
  action    String // e.g. ORDER_APPROVED, PRICE_CHANGED, PAYMENT_RECORDED
  entity    String
  entityId  String
  before    Json?
  after     Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId, createdAt])
}
